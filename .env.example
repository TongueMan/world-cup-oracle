WCPA_API_HOST=127.0.0.1
WCPA_API_PORT=8000
WCPA_RANDOM_SEED=42
WCPA_LOG_LEVEL=INFO
WCPA_PRIMARY_SOURCE=bing_sports
WCPA_ENABLE_BING_ONLY=true
WCPA_ENABLE_WEB_COLLECTORS=true
WCPA_ENABLE_PAGE_COLLECTORS=false
WCPA_ENABLE_AGENT_WEB_RETRIEVAL=false
WCPA_BING_MAX_SCROLL_PAGES=12
WCPA_POSTGRES_DB=wcpa
WCPA_POSTGRES_USER=postgre
WCPA_POSTGRES_PASSWORD=postgre
WCPA_POSTGRES_PORT=5432
WCPA_DATABASE_URL=postgresql://${WCPA_POSTGRES_USER}:${WCPA_POSTGRES_PASSWORD}@localhost:${WCPA_POSTGRES_PORT}/${WCPA_POSTGRES_DB}
WCPA_BING_SCHEDULE_URL=https://www.bing.com/sportsdetails?q=%E4%B8%96%E7%95%8C%E6%9D%AF%E8%B5%9B%E7%A8%8B&sport=Soccer&scenario=League&TimezoneId=China%20Standard%20Time&IANATimezoneId=Asia/Shanghai&ISOTimezoneKey=CST&league=Soccer_InternationalWorldCup&intent=Schedule&seasonyear=2026&segment=sports&isl2=true

# OpenAI-compatible LLM provider. Keep real keys only in local .env.
WCPA_ENABLE_LLM_AGENTS=true
WCPA_LLM_BASE_URL=https://api.deepseek.com
WCPA_LLM_MODEL=deepseek-chat
WCPA_LLM_API_KEY=

# Agent web search. Supported provider for the product Agent: firecrawl.
# Firecrawl API key is optional. If left blank, the backend attempts Keyless first;
# if Firecrawl returns 401/403, the Agent will clearly fall back instead of pretending to have searched.
WCPA_WEB_SEARCH_ENABLED=true
WCPA_SEARCH_PROVIDER=firecrawl
WCPA_FIRECRAWL_API_KEY=
WCPA_FIRECRAWL_MAX_QUERIES_PER_REQUEST=3
WCPA_FIRECRAWL_MAX_RESULTS=5
WCPA_FIRECRAWL_SCRAPE_TOP_N=3
WCPA_FIRECRAWL_TIMEOUT_SECONDS=20
WCPA_FIRECRAWL_MAX_PAGE_CHARS=12000
WCPA_SEARCH_CACHE_TTL_SECONDS=600

# API-Football odds snapshots for Agent match context. Keep real keys only in local .env.
WCPA_API_FOOTBALL_ODDS_ENABLED=true
WCPA_API_FOOTBALL_API_KEY=
WCPA_API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
WCPA_API_FOOTBALL_WORLD_CUP_LEAGUE_ID=1
WCPA_API_FOOTBALL_SEASON=2026
WCPA_API_FOOTBALL_DISCOVER_FIXTURE=true
WCPA_API_FOOTBALL_TIMEOUT_SECONDS=12
WCPA_API_FOOTBALL_MAX_BOOKMAKERS=4
WCPA_API_FOOTBALL_MAX_MARKETS=8

# Optional product-grade RAG layer. Uses PostgreSQL + pgvector when available.
WCPA_RAG_ENABLED=false
WCPA_RAG_VECTOR_BACKEND=pgvector
WCPA_EMBEDDING_PROVIDER=
WCPA_EMBEDDING_MODEL=
WCPA_EMBEDDING_API_KEY=
WCPA_EMBEDDING_BASE_URL=
